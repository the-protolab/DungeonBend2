# Public inline config for app/screen shell wrappers.

type ShellConfig {
  shell_layout{
    width: Midum/Layout/Width,
    max_width: Midum/Layout/MaxWidth,
    height: Midum/Layout/ShellHeight,
    overflow: Midum/Layout/ShellOverflow,
    safe_area: Midum/Layout/ShellSafeArea,
    inset: Midum/Layout/EdgeInsets,
    compact_inset: Midum/Layout/ShellCompactInset,
  }
}
